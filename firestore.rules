rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Any authenticated user can read profiles (needed to display names)
    // Only the owner can write their own profile
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    match /chats/{chatId} {
      // Only members can read or update a chat
      allow read: if request.auth != null && request.auth.uid in resource.data.members;
      // Creator must include themselves in members array
      allow create: if request.auth != null && request.auth.uid in request.resource.data.members;
      allow update: if request.auth != null && request.auth.uid in resource.data.members;

      match /messages/{msgId} {
        function isMember() {
          return request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.members;
        }
        // Only chat members can read messages
        allow read: if request.auth != null && isMember();
        // Only members can create, and senderId must match their uid
        allow create: if request.auth != null
          && isMember()
          && request.resource.data.senderId == request.auth.uid;
      }
    }
  }
}
